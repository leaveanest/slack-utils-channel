# Slack App Configuration
SLACK_APP_NAME=Slack Utils Template
SLACK_APP_DESCRIPTION=A template for Slack workflow development
SLACK_CATEGORY=Channel

# Slack Team ID (optional, automatically detected from context)
# For Enterprise Grid: Find your Team ID in the URL
# Format: https://app.slack.com/client/T1234567890/...
# The string starting with 'T' is your Team ID
# SLACK_TEAM_ID=T1234567890

# Admin User Token for private channel creation via Admin API
# Required for bypassing workspace channel creation restrictions
# Get this token from a traditional Slack app with admin.conversations:write scope
# Format: xoxp-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_ADMIN_USER_TOKEN=xoxp-your-admin-user-token-here

# Anthropic API Key for i18n translation
# Get your API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
